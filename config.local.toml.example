# Brewster local configuration example
#
# Copy this file to config.local.toml and fill in your local values.
# config.local.toml is ignored by git.

[env]
SSID = "your-ssid"
PASSWORD = "your-password"
DEVICE_HOSTNAME = "brewster"
WIFI_SCAN_EVERY_ATTEMPTS = "6"
STATUS_PRINT_EVERY_SECONDS = "5"
# DS18B20 ADC resolution (9, 10, 11, or 12 bits). Default: 11.
#   9-bit  →  94 ms conversion, 0.5 °C steps
#   10-bit → 188 ms conversion, 0.25 °C steps
#   11-bit → 375 ms conversion, 0.125 °C steps  ← default
#   12-bit → 750 ms conversion, 0.0625 °C steps
DS18B20_RESOLUTION = "11"
# SSR_DEADBAND = "0.5"  # Dead zone ±0.25°C around setpoint (default: 0.5 °C)
NTP_SERVERS = "129.6.15.28,194.58.204.20"
# Optional fallback when NTP_SERVERS is empty or invalid
NTP_SERVER = "8.8.8.8"

# SSR wiring (configurable via [ssr] below; defaults shown):
#   Cooling SSR → GPIO 12
#   Heating SSR → GPIO 13
#   DS18B20 data → GPIO 5  (configured via [[sensors]] below)

# UDP telemetry server (optional).  Set UDP_SERVER_IP to enable.
# brewster-server listens on port 47890 by default; run it on any LAN host.
# The dashboard served by the server is then accessible on http://<server>:8080
# UDP_SERVER_IP = "192.168.1.50"
# UDP_SERVEtheR_PORT = "47890"

[device]
hostname = "brewster"

[ssr]
cool_pin = 12  # GPIO pin for cooling SSR (default: 12)
heat_pin = 13  # GPIO pin for heating SSR (default: 13)
# SSR_DEADBAND = "0.5"  # Dead zone ±0.25°C around setpoint (default: 0.5 °C)

[[sensors]]
pin = 5
name = "probe-1"

# Add more probes by repeating [[sensors]]
# [[sensors]]
# pin = 6
# name = "probe-2"
